<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1A2E"
    android:scrollbars="none"
    tools:context=".SignupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Hero Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="44dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"
                android:contentDescription="Hagit AI Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Hagit.AI"
                android:textColor="#F0F4F8"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Start your debate mastery journey"
                android:textColor="#4A6A7A"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_form_card"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- Full Name Row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full name"
                android:textColor="#4A6A7A"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/inputFirstName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:hint="First name"
                    android:textColorHint="#3A5A6A"
                    android:textColor="#E2EAF2"
                    android:textSize="13sp"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"
                    android:inputType="textPersonName" />

                <EditText
                    android:id="@+id/inputLastName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:hint="Last name"
                    android:textColorHint="#3A5A6A"
                    android:textColor="#E2EAF2"
                    android:textSize="13sp"
                    android:padding="12dp"
                    android:layout_marginStart="4dp"
                    android:inputType="textPersonName" />

            </LinearLayout>

            <!-- BISU Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email"
                android:textColor="#4A6A7A"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/inputEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_field"
                android:hint="create your@email"
                android:textColorHint="#3A5A6A"
                android:textColor="#E2EAF2"
                android:textSize="13sp"
                android:padding="12dp"
                android:inputType="textEmailAddress" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Use your institutional email address"
                android:textColor="#2A4A5A"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#4A6A7A"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:hint="Create a password"
                    android:textColorHint="#3A5A6A"
                    android:textColor="#E2EAF2"
                    android:textSize="13sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:inputType="textPassword" />

                <ImageView
                    android:id="@+id/togglePassword"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_eye"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#3A5A6A" />

            </RelativeLayout>

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm password"
                android:textColor="#4A6A7A"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/inputConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:hint="Repeat your password"
                    android:textColorHint="#3A5A6A"
                    android:textColor="#E2EAF2"
                    android:textSize="13sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:inputType="textPassword" />

                <ImageView
                    android:id="@+id/toggleConfirmPassword"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_eye"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#3A5A6A" />

            </RelativeLayout>

           " />

            <!-- Terms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="20dp">

                <CheckBox
                    android:id="@+id/checkboxTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#378ADD"
                    android:layout_marginTop="1dp"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="15dp"
                    android:text="I agree to the Terms of Service and Privacy Policy of Hagit.AI"
                    android:textColor="#6B8A9A"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- Create Account Button -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Create account"
                android:textColor="#E1F5EE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

            <!-- Sign In Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#4A6A7A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in"
                    android:textColor="#378ADD"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>