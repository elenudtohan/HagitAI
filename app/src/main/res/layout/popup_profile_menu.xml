<?xml version="1.0" encoding="utf-8"?>
<!--
    popup_profile_menu.xml
    Place this file in: res/layout/popup_profile_menu.xml

    Inflated by ProfileActivity.showHamburgerMenu().
    Background is set programmatically to @drawable/rounded_card.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:background="@drawable/rounded_card_bg"
    android:paddingBottom="6dp">

    <!-- History -->
    <TextView
        android:id="@+id/menuHistory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="📜  History"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#334A6A" />

    <!-- About -->
    <TextView
        android:id="@+id/menuAbout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="ℹ️  About"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#334A6A" />

    <!-- Log Out -->
    <TextView
        android:id="@+id/menuLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="🚪  Log Out"
        android:textColor="#FF6B6B"
        android:textSize="14sp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>