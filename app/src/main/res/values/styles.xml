<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CalendarHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#E0E0E0</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="CalendarDayInactive">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#E0E0E0</item>
        <item name="android:background">@drawable/day_inactive_bg</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CalendarDayActive">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/day_active_bg</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>