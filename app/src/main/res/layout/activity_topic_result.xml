<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    tools:context=".TopicResultActivity">

    <!-- Outer card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btn_outline_green"
        android:padding="24dp"
        android:elevation="8dp"
        android:layout_margin="16dp">

        <!-- X Close Button - top right -->
        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_close_btn"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Close"
            app:tint="#CBE2FF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lightbulb Icon Box -->
        <LinearLayout
            android:id="@+id/iconBox"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:background="@drawable/bg_icon_box"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnClose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_lightbulb"
                android:contentDescription="Topic"
                app:tint="#DCB85F" />

        </LinearLayout>

        <!-- Label -->
        <TextView
            android:id="@+id/textLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEBATE TOPIC"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/iconBox"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Topic Box -->
        <TextView
            android:id="@+id/textTopic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Should AI replace human workers in creative industries?"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_topic_box"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/textLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Start Debate Button -->
        <LinearLayout
            android:id="@+id/btnStartDebate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_btn_green"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/textTopic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_play"
                android:contentDescription="Start"
                app:tint="#0f1a2e"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start debate"
                android:textColor="#0f1a2e"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Generate Again Button -->
        <LinearLayout
            android:id="@+id/btnGenerateAgain"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_btn_outline_green"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btnStartDebate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_refresh"
                android:contentDescription="Regenerate"
                app:tint="#60CC8B"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate again"
                android:textColor="#60CC8B"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>