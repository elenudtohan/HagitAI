<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<ScrollView 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start|center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Hagit.AI"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Combined Profile and Menu Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"

                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">


                <LinearLayout
                    android:id="@+id/profileBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/profileImage"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_profile"
                        android:scaleType="centerCrop"
                        android:background="@drawable/badge_card"
                        android:padding="4dp"
                        android:contentDescription="Profile"/>
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>

        <!-- Welcome Section -->
        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, Juan! 👋 "
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/subText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready to sharpen your debate skills today?"
            android:textColor="#B0C4DE"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Level Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/fireAnim"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                app:lottie_fileName="fire_animation.json"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                android:contentDescription="Fire Animation" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/levelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level 1 "
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep debating to level up! 🔥"
                    android:textColor="#B0C4DE"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/xpBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Topic of the Day -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Topic of the Day"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/topicDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oct 25"
                    android:textColor="#B0C4DE"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/topicTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Should professional athletes be considered role models?"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 New topic daily at midnight"
                android:textColor="#B0C4DE"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 3 Square Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- Quick Debate -->
            <LinearLayout
                android:id="@+id/quickDebateBtn"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_badge_green"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_quick_debate"
                    android:contentDescription="Quick Debate"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Quick Debate"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Practice Mode -->
            <LinearLayout
                android:id="@+id/practiceBtn"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_badge_green"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_practice"
                    android:contentDescription="Practice"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Practice Mode"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Random Topic -->
            <LinearLayout
                android:id="@+id/randomBtn"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_badge_green"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_random"
                    android:contentDescription="Random"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Random Topic"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Throne Ranking Button -->
        <LinearLayout
            android:id="@+id/leaderboardBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_throne"
                android:background="@drawable/rounded_glass_square"
                android:padding="6dp"
                android:contentDescription="Throne Ranking"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Throne Ranking"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Ranking List Card -->
        <LinearLayout
            android:id="@+id/leaderboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <!-- Rank Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏆 Top Debaters"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/seeAllRanking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All"
                    android:textColor="#B0C4DE"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Rank Row 1 -->
            <LinearLayout
                android:id="@+id/rank1Row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/rounded_glass_square"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/rank1Number"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="👑"
                    android:textSize="18sp"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/rank1Avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/rounded_glass_square"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rank1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rank1Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0 · Loading"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rank1XP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XP"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Rank Row 2 -->
            <LinearLayout
                android:id="@+id/rank2Row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/rounded_glass_square"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/rank2Number"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="🥈"
                    android:textSize="18sp"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/rank2Avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/rounded_glass_square"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rank2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rank2Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0 · Loading"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rank2XP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XP"
                    android:textColor="#C0C0C0"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Rank Row 3 -->
            <LinearLayout
                android:id="@+id/rank3Row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/rounded_glass_square"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/rank3Number"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="🥉"
                    android:textSize="18sp"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/rank3Avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/rounded_glass_square"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rank3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rank3Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0 · Loading"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rank3XP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XP"
                    android:textColor="#CD7F32"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Rank Row 4 -->
            <LinearLayout
                android:id="@+id/rank4Row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/rounded_glass_square"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/rank4Number"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="#B0C4DE"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/rank4Avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/rounded_glass_square"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rank4Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rank4Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0 · Loading"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rank4XP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XP"
                    android:textColor="#B0C4DE"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Rank Row 5 -->
            <LinearLayout
                android:id="@+id/rank5Row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/rounded_glass_square">

                <TextView
                    android:id="@+id/rank5Number"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#B0C4DE"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/rank5Avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/rounded_glass_square"
                    android:padding="6dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rank5Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rank5Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0 · Loading"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rank5XP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 XP"
                    android:textColor="#B0C4DE"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>

    <!-- Side Menu -->
    <include layout="@layout/activity_menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>