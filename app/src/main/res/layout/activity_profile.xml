<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Navigation -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A2D4A"
            android:paddingTop="36dp"
            android:paddingBottom="4dp"
            android:paddingStart="22dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:padding="4dp"
                app:tint="#CBE2FF" />

            <ImageView
                android:id="@+id/ivHamburger"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:padding="4dp"
                app:tint="#CBE2FF" />
        </RelativeLayout>

        <!-- Profile Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A2D4A"
            android:paddingBottom="24dp"
            android:paddingStart="22dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:id="@+id/headerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Avatar circle -->
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center"
                    android:paddingTop="2dp"
                    android:layout_marginTop="16dp"
                    android:text="EU"
                    android:textColor="#0F1A2E"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elen Udtohan"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- BIO DISPLAY MODE -->
                <LinearLayout
                    android:id="@+id/layoutBioDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvBioDisplay"
                        android:layout_width="230dp"
                        android:layout_height="wrap_content"
                        android:text="jst for fun"
                        android:textColor="#CBE2FF"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:maxLines="3"
                        android:ellipsize="end"
                        android:hint="Write something about yourself..."
                        android:textColorHint="#4A6A8A" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="15dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Edit Bio"
                        app:tint="#CBE2FF" />

                </LinearLayout>

                <!-- BIO EDIT MODE -->
                <LinearLayout
                    android:id="@+id/layoutBioEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etBio"
                        android:layout_width="230dp"
                        android:layout_height="wrap_content"
                        android:text="jst for fun"
                        android:textColor="#CBE2FF"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_bio_input"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:minLines="1"
                        android:hint="Write something about yourself..."
                        android:textColorHint="#4A6A8A"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnSaveBio"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Save changes"
                            android:textSize="12sp"
                            android:textColor="#0F1A2E"
                            android:textStyle="bold"
                            android:backgroundTint="#60CC8B"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button" />

                        <Button
                            android:id="@+id/btnCancelBio"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Cancel"
                            android:textSize="12sp"
                            android:textColor="#CBE2FF"
                            android:backgroundTint="@android:color/transparent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#4A6A8A"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>



            </LinearLayout>

            </LinearLayout>
        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="3"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:id="@+id/tvDebateCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18"
                    android:textColor="#60CC8B"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Debates"
                    android:textColor="#99CBE2FF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:id="@+id/tvWinCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="#60CC8B"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wins"
                    android:textColor="#99CBE2FF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:id="@+id/tvWinRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11%"
                    android:textColor="#60CC8B"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Win rate"
                    android:textColor="#99CBE2FF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Level Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL STATUS"
                android:textColor="#99CBE2FF"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Level 2 — Bronze"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvXP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150 / 200 XP"
                    android:textColor="#99CBE2FF"
                    android:textSize="12sp" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressXP"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="75"
                android:max="100"
                android:progressDrawable="@drawable/xp_progress_bar"
                android:background="@drawable/xp_progress_bg"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvNextLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50 XP to Level 3 — Bronze"
                android:textColor="#66CBE2FF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Badges Earned Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_card"
            android:padding="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BADGES EARNED"
                android:textColor="#99CBE2FF"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5"
                android:baselineAligned="false"
                android:gravity="center_vertical">

                <!-- First win Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_badge_gold"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_badge_star"
                            android:contentDescription="First win badge" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First win"
                        android:textColor="#FFB300"
                        android:textSize="10sp"
                        android:textAlignment="center"/>
                </LinearLayout>

                <!-- Wins Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_trophy"
                            app:tint="#60CC8B"
                            android:contentDescription="Wins badge" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBadgeWinsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Wins"
                        android:textColor="#60CC8B"
                        android:textSize="10sp"
                        android:textAlignment="center"/>
                </LinearLayout>

                <!-- Gold Badge (30 Wins) -->
                <LinearLayout
                    android:id="@+id/layoutGoldBadge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/bgGoldBadge"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_badge_locked"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:id="@+id/ivGoldBadgeIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_medal_gold"
                            app:tint="#4A6A8A"
                            android:contentDescription="Gold badge" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvGoldBadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gold"
                        android:textColor="#4A6A8A"
                        android:textSize="10sp"
                        android:textAlignment="center"/>
                </LinearLayout>

                <!-- Social Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_people"
                            app:tint="#5B8BF6"
                            android:contentDescription="Social badge" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Social"
                        android:textColor="#5B8BF6"
                        android:textSize="10sp"
                        android:textAlignment="center"/>
                </LinearLayout>

                <!-- Profile pro Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_badge_pink"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_badge_profile"
                            android:contentDescription="Profile pro badge" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile pro"
                        android:textColor="#D4537E"
                        android:textSize="10sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
    </ScrollView>
