<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient colors -->
    <gradient
        android:startColor="#FF007CF0"
        android:endColor="#FF9327FF"
        android:angle="90" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Padding -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="8dp"
        android:bottom="8dp" />
</shape>


