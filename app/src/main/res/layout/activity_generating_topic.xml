<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    tools:context=".GeneratingTopicActivity">

    <!-- Glass card -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="250dp"
        android:background="@drawable/glass_bg"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:elevation="6dp"
        android:layout_margin="16dp">

        <!-- Icon: lightbulb for topic generation -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="Generating a topic"
            android:src="@drawable/ic_lightbulb"
            app:tint="#F6CC64" />

        <!-- Title -->
        <TextView
            android:id="@+id/textGenerating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generating Topic..."
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Picking a topic for your debate...."
            android:textColor="#CBE2FF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Loading dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp" />

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>