<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient"
    android:padding="20dp"
    tools:context=".DebateActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Timer only -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_glass_square"
                android:padding="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_timer"
                    android:contentDescription="Timer"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/textTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:54"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Opponent Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/rounded_glass_square"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="Opponent" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textParticipantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maria Santos"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/textParticipantCourse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BSIT · Level 9"
                    android:textColor="#B0C4DE"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Online Badge -->
            <TextView
                android:id="@+id/textOnlineStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Online"
                android:textColor="#00E676"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_glass_square"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- Debate Topic Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠 Debate Topic"
                android:textColor="#B0C4DE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/textDebateTopic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Is competition beneficial in education?"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Chat / Debate Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/rounded_card"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/rounded_glass_square"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_quick_debate"
                    android:contentDescription="Debate" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Start the debate by submitting\nyour opening argument below"
                android:textColor="#B0C4DE"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Input Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/rounded_card"
            android:padding="10dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/inputArgument"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type your argument here..."
                android:textColorHint="#B0C4DE"
                android:textColor="@android:color/white"
                android:inputType="textMultiLine"
                android:background="@android:color/transparent"
                android:minHeight="48dp"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/btnSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/rounded_button_blue"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_send"
                    android:contentDescription="Send" />
            </LinearLayout>
        </LinearLayout>

        <!-- Exit & Forfeit Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/rounded_card"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exit"
                    android:textColor="#00E676"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnForfeit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/rounded_card"
                android:clickable="true"
                android:focusable="true">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forfeit"
                    android:textColor="#FF5252"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tip Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:padding="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Build strong arguments with evidence and address your opponent's points directly"
                android:textColor="#B0C4DE"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>